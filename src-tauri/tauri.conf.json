{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Feuilles de temps",
  "version": "0.1.0",
  "identifier": "com.timesheet.tracker",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../client/dist",
    "beforeDevCommand": "bun run build:server && cp src-tauri/timesheet-server-aarch64-apple-darwin src-tauri/target/debug/timesheet-server && cd client && bun run dev",
    "beforeBuildCommand": "cd client && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Feuilles de temps",
        "width": 1024,
        "height": 768,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3001; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "timesheet-server"
    ],
    "resources": {
      "../client/dist": "webroot/"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
